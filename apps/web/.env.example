# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Database (Drizzle ORM - Supabase Postgres connection string)
DATABASE_URL=

# Google AI (Gemini)
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-key

# E2B (Synthetic test sandbox)
E2B_API_KEY=your-e2b-api-key
E2B_TEMPLATE=sandterm-mcp-gateway
E2B_SANDBOX_ID=synthetic-test
E2B_SANDBOX_TIMEOUT=900000

# Firecrawl (web scraping MCP)
FIRECRAWL_API_KEY=your-firecrawl-api-key

# App URL (used for generating links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret (must match the value in synthetic_test.config table)
CRON_SECRET=
